↓

Previous Salary

↓

Running Total
```

Single Query

```sql
SELECT

employee_name,

department,

salary,

AVG(salary)

OVER
(
PARTITION BY department
)

AS department_average,

SUM(salary)

OVER
(
PARTITION BY department
)

AS department_total,

RANK()

OVER
(
ORDER BY salary DESC
)

AS company_rank,

ROW_NUMBER()

OVER
(
PARTITION BY department

ORDER BY salary DESC
)

AS department_rank,

LAG(salary)

OVER
(
PARTITION BY department

ORDER BY salary DESC
)

